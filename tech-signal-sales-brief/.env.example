# ──────────────────────────────────────────────────────────────────────
# Tech Signal Sales Brief — Environment Variables
# ──────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control.
# ──────────────────────────────────────────────────────────────────────

# ─── Data Source API Keys ─────────────────────────────────────────────

# GitHub Personal Access Token (for searching Issues)
# Create at: https://github.com/settings/tokens (needs "public_repo" scope)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stack Exchange API Key (for searching Stack Overflow)
# Register at: https://stackapps.com/apps/oauth/register
STACKEXCHANGE_API_KEY=xxxxxxxxxxxxxxxx

# Google Developer Knowledge MCP API Key (for official docs grounding)
# Obtain from: https://aistudio.google.com/apikey
DK_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Email / SMTP Configuration ──────────────────────────────────────
# Required for the batch job to send PDF reports via email.
#
# Gmail example (requires App Password):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=you@gmail.com
#   SMTP_PASSWORD=xxxx xxxx xxxx xxxx   (16-char App Password)
#
# Create a Gmail App Password at:
#   https://myaccount.google.com/apppasswords

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com

# ─── Batch Job Overrides (optional) ──────────────────────────────────

# Override the schedule day (monday, tuesday, ... friday)
# SCHEDULE_DAY=friday

# Override the analysis prompt entirely
# SCHEDULE_PROMPT=Analyze BigQuery cost optimization signals

# Skip email delivery (just save PDF locally to output/)
# BATCH_SKIP_EMAIL=true
